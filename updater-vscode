# --- 3. Elevation & Self-Sync ---
if [[ $EUID -ne 0 ]]; then
    log_audit "ELEVATION: Administrative privileges required. Re-executing as root."
    exec sudo "$0" "$@"
    exit $?
fi

# Create log file if missing
if [[ ! -f "$LOG_FILE" ]]; then
    touch "$LOG_FILE"
    chmod 644 "$LOG_FILE"
fi

# Install script to /usr/local/bin if needed
if [[ "$(realpath "$0")" != "$SCRIPT_PATH" ]]; then
    log_audit "ACTION: Installing script to $SCRIPT_PATH"
    mkdir -p "$(dirname "$SCRIPT_PATH")"
    cp -f "$0" "$SCRIPT_PATH"
    chmod 755 "$SCRIPT_PATH"
    chown root:wheel "$SCRIPT_PATH"
fi

# Sync LaunchDaemon schedule
PROPOSED_PLIST_HASH=$(echo "$PLIST_CONTENT" | shasum -a 256 | awk '{print $1}')
CURRENT_PLIST_HASH=$(shasum -a 256 "$PLIST_PATH" 2>/dev/null | awk '{print $1}')
if [[ "$PROPOSED_PLIST_HASH" != "$CURRENT_PLIST_HASH" ]]; then
    log_audit "ACTION: Syncing LaunchDaemon schedule..."
    echo "$PLIST_CONTENT" > "$PLIST_PATH"
    chmod 644 "$PLIST_PATH"
    chown root:wheel "$PLIST_PATH"
    launchctl unload -w "$PLIST_PATH" 2>/dev/null
    launchctl load -w "$PLIST_PATH"
fi

trap 'rm -rf "${DEPLOY_WORKSPACE}"; log_audit "CLEANUP: Secure staging workspace purged."' EXIT

log_audit "-------------------------------------------------------------------------------"
log_audit "STARTING DEPLOYMENT: updater-vscode v1.2 | STAMP: 20260331-101500"
log_audit "-------------------------------------------------------------------------------"

# --- 4. API Manifest Resolution ---
log_audit "ACTION: Resolving remote version from Microsoft API..."
RELEASE_JSON=$(curl -sL -A "$UA" "$API_URL")

REMOTE_VER=$(echo "$RELEASE_JSON" | jq -r '.name // empty')
EXPECTED_HASH=$(echo "$RELEASE_JSON" | jq -r '.sha256hash // empty')
DOWNLOAD_URL=$(echo "$RELEASE_JSON" | jq -r '.url // empty')

if [[ -z "$REMOTE_VER" || -z "$DOWNLOAD_URL" ]]; then
    log_audit "WARNING: Microsoft API returned empty manifest. Skipping binary update."
else
    REMOTE_FILENAME=$(basename "$DOWNLOAD_URL")
    readonly VERSION_CACHE_DIR="${CACHE_ROOT}/${REMOTE_VER}/${ARCH_LABEL}"
    readonly LOCAL_ASSET_PATH="${VERSION_CACHE_DIR}/${REMOTE_FILENAME}"

    # --- 5. Vault Audit ---
    mkdir -p "$VERSION_CACHE_DIR"
    chmod 755 /Users/Shared/CachedInstallers "$CACHE_ROOT" "${CACHE_ROOT}/${REMOTE_VER}" "$VERSION_CACHE_DIR"

    if [[ ! -f "$LOCAL_ASSET_PATH" ]]; then
        log_audit "ACTION: Cache miss. Downloading v$REMOTE_VER..."
        curl -L -f -sS -A "$UA" -o "$LOCAL_ASSET_PATH" "$DOWNLOAD_URL"
        chmod 644 "$LOCAL_ASSET_PATH"
        LOCAL_HASH=$(shasum -a 256 "$LOCAL_ASSET_PATH" | awk '{print $1}')
        [[ "$LOCAL_HASH" != "$EXPECTED_HASH" ]] && { log_audit "FAILURE: SHA-256 handshake failed."; exit 1; }
        log_audit "SUCCESS: v$REMOTE_VER vaulted and verified."
    else
        log_audit "SKIP: Vault integrity confirmed for v$REMOTE_VER ($ARCH_LABEL)."
    fi

    # --- 6. Binary Synchronization ---
    [[ -d "$APP_TARGET" ]] && LOCAL_APP_VER=$(defaults read "${APP_TARGET}/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null) || LOCAL_APP_VER="absent"

    if [[ "$LOCAL_APP_VER" != "$REMOTE_VER" ]]; then
        log_audit "ACTION: Version drift (Installed: $LOCAL_APP_VER, Target: $REMOTE_VER)."
        if pgrep -f "$APP_NAME" > /dev/null; then
            pkill -SIGTERM -f "$APP_NAME"; sleep 2; pgrep -f "$APP_NAME" > /dev/null && pkill -SIGKILL -f "$APP_NAME"
        fi
        mkdir -p "${EXTRACT_DIR}"
        if unzip -q -o "$LOCAL_ASSET_PATH" -d "${EXTRACT_DIR}"; then
            rm -rf "$APP_TARGET"
            mv "${EXTRACT_DIR}/Visual Studio Code.app" "/Applications/"
            xattr -rd com.apple.quarantine "$APP_TARGET" 2>/dev/null
            ln -sf "$APP_TARGET/Contents/Resources/app/bin/code" "$BIN_LINK"
            CHANGES_DETECTED=true; log_audit "SUCCESS: Binary updated to v$REMOTE_VER."
        fi
    else
        log_audit "SKIP: Binary v$LOCAL_APP_VER is current."
    fi
fi

# --- 7. Forensic Profile Enforcement ---
echo "$STD_SETTINGS" > "$BASELINE_JSON"
chmod 644 "$BASELINE_JSON"

COUNT_LEAFS() {
    echo "$1" | jq '[.. | scalars] | length' 2>/dev/null || echo "0"
}

GOLDEN_COUNT=$(COUNT_LEAFS "$STD_SETTINGS")

SUMMARY_TABLE="\n%-15s | %-10s | %-12s | %-12s | %-10s\n"
SUMMARY_TABLE+=$(printf "%-15s | %-10s | %-12s | %-12s | %-10s" "USER" "STATUS" "ENFORCED" "PRESERVED" "TOTAL")
SUMMARY_TABLE+="\n-------------------------------------------------------------------------------"

while IFS= read -r user; do
    home=$(dscl . -read "/Users/$user" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
    if [[ -d "$home" && "$home" =~ ^/Users/ && "$user" != "Shared" ]]; then
        u_file="${home}/Library/Application Support/Code/User/settings.json"
        mkdir -p "$(dirname "$u_file")"

        # Null-Safe Check
        if [[ ! -f "$u_file" ]] || ! jq -e . "$u_file" >/dev/null 2>&1; then
            log_audit "ACTION: Repairing JSON structure for [$user]..."
            echo "{}" > "$u_file"
            chown "$user":staff "$u_file"
        fi

        CURRENT_JSON=$(cat "$u_file")
        # Ensure merge handles empty/null files correctly
        PROPOSED_JSON=$(sudo -u "$user" jq -s 'if .[0] == null then {} else .[0] end * .[1]' "$u_file" "$BASELINE_JSON")

        DRIFT_KEYS=$(sudo -u "$user" jq -r --argjson gold "$STD_SETTINGS" 'if type=="object" then (keys - ($gold | keys) | .[]) else empty end' "$u_file" 2>/dev/null)

        if [[ -n "$DRIFT_KEYS" ]]; then
            log_audit "INFO | User [$user] preserves custom settings:"
            echo "$DRIFT_KEYS" | sed 's/^/  - /'
        fi

        if [[ "$CURRENT_JSON" != "$PROPOSED_JSON" ]]; then
            log_audit "ACTION: Hardening settings for [$user]..."
            echo "$PROPOSED_JSON" > "$u_file"
            chown "$user":staff "$u_file"; chmod 644 "$u_file"
            CHANGES_DETECTED=true
        else
            log_audit "PASS: Profile for [$user] matches standard."
        fi

        u_total=$(COUNT_LEAFS "$PROPOSED_JSON")
        u_preserved=$((u_total - GOLDEN_COUNT))

        SUMMARY_TABLE+=$(printf "\n%-15s | %-10s | %-12s | %-12s | %-10s" "$user" "VALID" "$GOLDEN_COUNT" "$u_preserved" "$u_total")
    fi
done < <(dscl . -list /Users)

# --- 8. Maintenance ---
log_audit "ACTION: Pruning vault (Retention: $CACHE_LIMIT)..."
ls -1dt "${CACHE_ROOT}"/*/ 2>/dev/null | tail -n +$((CACHE_LIMIT + 1)) | xargs rm -rf 2>/dev/null

# --- 9. Final Disposition ---
log_audit "-------------------------------------------------------------------------------"
log_audit "DEPLOYMENT SUMMARY:"
printf "$SUMMARY_TABLE\n"
log_audit "-------------------------------------------------------------------------------"

if [[ "$CHANGES_DETECTED" == true ]]; then
    log_audit "FINAL STATUS: SUCCESS | System synchronized."
    sudo -u "$(stat -f%Su /dev/console)" open -a "$APP_NAME" 2>/dev/null
else
    log_audit "FINAL STATUS: SUCCESS | System matches Golden State."
fi
